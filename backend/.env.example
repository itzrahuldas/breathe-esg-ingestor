# Backend environment variables
# Copy this to .env and fill in values for local development.
# On Render, set these via the Dashboard → Environment tab.

# Django
DJANGO_SECRET_KEY=dev-insecure-key-change-me-in-production-breathe-esg-2024
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave blank to use SQLite locally)
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# CORS
CORS_ALLOW_ALL=True
# CORS_ALLOWED_ORIGINS=https://breathe-esg.vercel.app

# Logging
LOG_LEVEL=DEBUG
